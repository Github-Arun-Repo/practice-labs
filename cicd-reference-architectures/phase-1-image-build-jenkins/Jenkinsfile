pipeline {
    agent {
        kubernetes {
            label 'todo-app'
            defaultContainer 'maven'
            yamlFile 'cicd-reference-architectures/phase-1-image-build-jenkins/pod-template.yaml'
        }
    }

    environment {
        PIPELINE_VERSION = 'security-reports-syft-sbom-v2-2026-07-17'
        REGISTRY = 'docker.io'  // Change to your registry: gcr.io, ecr, etc.
        IMAGE_NAME = 'agovindasamy/arun'
        IMAGE_TAG = "${BUILD_NUMBER}"
        LATEST_TAG = 'latest'
        GIT_REPO = 'https://github.com/Github-Arun-Repo/platform-engineering-reference-architectures.git'
        GITHUB_CREDENTIALS_ID = 'github-arun-repository'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-credentials'
        SECURITY_REPORT_DIR = 'security-reports'
        GITLEAKS_VERSION = '8.24.2'
        SYFT_IMAGE = 'anchore/syft:latest'
        ORAS_VERSION = '1.2.2'
        SONARQUBE_SERVER = 'SonarQube'  // Configure in Jenkins
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '15'))
        // Keep a generous global timeout and rely on stage-level timeouts for scan tools.
        timeout(time: 180, unit: 'MINUTES')
        // Avoid aborting an in-flight build when report commits trigger a new build.
        disableConcurrentBuilds(abortPrevious: false)
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Pipeline version: ${PIPELINE_VERSION}"
                    echo "Checking out source code from ${GIT_REPO}"
                }
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[url: "${GIT_REPO}", credentialsId: "${GITHUB_CREDENTIALS_ID}"]]
                ])
            }
        }

        stage('Build & Test') {
            steps {
                container('maven') {
                    script {
                        echo "Building and testing TODO application..."
                        dir('cicd-reference-architectures/sample-application') {
                            sh 'mvn clean test'
                        }
                    }
                }
            }
        }

        // stage('Code Quality Analysis') {
        //     // Requires: SonarQube server + sonar Jenkins plugin (plugin ID: sonar)
        //     // Skip this stage if SonarQube is not configured in your environment
        //     steps {
        //         script {
        //             echo "Running SonarQube analysis..."
        //             dir('cicd-reference-architectures/sample-application') {
        //                 withSonarQubeEnv("${SONARQUBE_SERVER}") {
        //                     sh 'mvn sonar:sonar'
        //                 }
        //             }
        //         }
        //     }
        // }

        stage('Build Application') {
            steps {
                container('maven') {
                    script {
                        echo "Packaging Spring Boot application..."
                        dir('cicd-reference-architectures/sample-application') {
                            sh 'mvn clean package -DskipTests'
                        }
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                container('docker') {
                    script {
                        echo "Building Docker image: ${IMAGE_NAME}:${IMAGE_TAG}"
                        dir('cicd-reference-architectures/sample-application') {
                            sh '''
                                docker build \
                                    -t ${IMAGE_NAME}:${IMAGE_TAG} \
                                    -t ${IMAGE_NAME}:${LATEST_TAG} \
                                    -f Dockerfile .
                            '''
                        }
                    }
                }
            }
        }

        stage('Generate Image SBOM') {
            steps {
                container('docker') {
                    script {
                        echo "Generating SBOM for Docker image: ${IMAGE_NAME}:${IMAGE_TAG}"
                        sh '''
                            mkdir -p ${SECURITY_REPORT_DIR}
                            rm -f ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json \
                                  ${SECURITY_REPORT_DIR}/sbom.spdx.json \
                                  ${SECURITY_REPORT_DIR}/sbom.syft.txt \
                                  ${SECURITY_REPORT_DIR}/sbom-report.html \
                                  ${SECURITY_REPORT_DIR}/sbom-syft.log

                            echo "Running Syft CycloneDX JSON scan for ${IMAGE_NAME}:${IMAGE_TAG}"
                            docker run --rm \
                                -v /var/run/docker.sock:/var/run/docker.sock \
                                ${SYFT_IMAGE} \
                                docker:${IMAGE_NAME}:${IMAGE_TAG} \
                                -o cyclonedx-json \
                                > ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json \
                                2> ${SECURITY_REPORT_DIR}/sbom-syft.log

                            echo "Running Syft SPDX JSON scan for ${IMAGE_NAME}:${IMAGE_TAG}"
                            docker run --rm \
                                -v /var/run/docker.sock:/var/run/docker.sock \
                                ${SYFT_IMAGE} \
                                docker:${IMAGE_NAME}:${IMAGE_TAG} \
                                -o spdx-json \
                                > ${SECURITY_REPORT_DIR}/sbom.spdx.json \
                                2>> ${SECURITY_REPORT_DIR}/sbom-syft.log

                            echo "Running Syft table scan for ${IMAGE_NAME}:${IMAGE_TAG}"
                            docker run --rm \
                                -v /var/run/docker.sock:/var/run/docker.sock \
                                ${SYFT_IMAGE} \
                                docker:${IMAGE_NAME}:${IMAGE_TAG} \
                                -o table \
                                > ${SECURITY_REPORT_DIR}/sbom.syft.txt \
                                2>> ${SECURITY_REPORT_DIR}/sbom-syft.log

                            GENERATED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
                            CYCLONEDX_BYTES="$(wc -c < ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json | tr -d ' ')"
                            SPDX_BYTES="$(wc -c < ${SECURITY_REPORT_DIR}/sbom.spdx.json | tr -d ' ')"
                            TABLE_BYTES="$(wc -c < ${SECURITY_REPORT_DIR}/sbom.syft.txt | tr -d ' ')"
                            PACKAGE_LINES="$(tail -n +2 ${SECURITY_REPORT_DIR}/sbom.syft.txt | grep -c . || true)"

                            cat > ${SECURITY_REPORT_DIR}/sbom-report.html <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image SBOM Report</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: #f6f8fa; color: #24292f; margin: 0; padding: 32px; }
        .panel { max-width: 980px; margin: 0 auto; background: #fff; border: 1px solid #d0d7de; border-radius: 8px; padding: 24px; }
        .meta { color: #57606a; margin: 8px 0 18px; }
        .badge { display: inline-block; background: #ddf4ff; color: #0969da; border-radius: 999px; padding: 4px 10px; font-size: 0.8rem; font-weight: 600; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; margin: 20px 0; }
        .metric { border: 1px solid #d0d7de; border-radius: 8px; padding: 14px; background: #f6f8fa; }
        .metric strong { display: block; font-size: 1.15rem; color: #24292f; }
        .metric span { color: #57606a; font-size: 0.82rem; }
        .actions { display: flex; flex-wrap: wrap; gap: 10px; margin: 20px 0; }
        .actions a { display: inline-block; padding: 9px 14px; border-radius: 6px; background: #1f6feb; color: #fff; text-decoration: none; font-size: 0.9rem; }
        .actions a.secondary { background: #57606a; }
        pre { background: #0d1117; color: #c9d1d9; border-radius: 8px; padding: 16px; overflow: auto; max-height: 420px; font-size: 0.8rem; }
    </style>
</head>
<body>
    <div class="panel">
        <h1>Image SBOM Report</h1>
        <p class="meta">Image: <strong>${IMAGE_NAME}:${IMAGE_TAG}</strong></p>
        <p class="badge">Generated by Syft</p>
        <div class="grid">
            <div class="metric"><strong>CycloneDX JSON</strong><span>${CYCLONEDX_BYTES} bytes - primary SBOM format</span></div>
            <div class="metric"><strong>SPDX JSON</strong><span>${SPDX_BYTES} bytes - alternate interchange format</span></div>
            <div class="metric"><strong>${PACKAGE_LINES}</strong><span>package rows in Syft table output</span></div>
            <div class="metric"><strong>${GENERATED_AT}</strong><span>generated at UTC</span></div>
        </div>
        <div class="actions">
            <a href="sbom.cyclonedx.json">Open CycloneDX JSON</a>
            <a href="sbom.spdx.json" class="secondary">Open SPDX JSON</a>
            <a href="sbom.syft.txt" class="secondary">Open Syft Table</a>
        </div>
        <h2>Package Inventory Preview</h2>
        <pre>$(sed -n '1,80p' ${SECURITY_REPORT_DIR}/sbom.syft.txt)</pre>
    </div>
</body>
</html>
EOF

                            echo "Syft SBOM generation complete. Report sizes:"
                            wc -c ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json \
                                  ${SECURITY_REPORT_DIR}/sbom.spdx.json \
                                  ${SECURITY_REPORT_DIR}/sbom.syft.txt \
                                  ${SECURITY_REPORT_DIR}/sbom-report.html
                        '''
                    }
                }
            }
        }

        stage('Scan Docker Image') {
            steps {
                container('docker') {
                    script {
                        echo "Scanning Docker image for vulnerabilities..."
                        // Security gating policy is intentionally not enforced in this pipeline.
                        // This stage always generates reports and never fails the build.
                        sh '''
                                mkdir -p ${SECURITY_REPORT_DIR}
                                rm -f ${SECURITY_REPORT_DIR}/trivy-report.json ${SECURITY_REPORT_DIR}/trivy-report.html

                                echo "Running Trivy JSON scan for ${IMAGE_NAME}:${IMAGE_TAG}"
                                docker run --rm \
                                    -v /var/run/docker.sock:/var/run/docker.sock \
                                    aquasec/trivy:0.57.1 image \
                                    --format json \
                                    --severity LOW,MEDIUM,HIGH,CRITICAL \
                                    --scanners vuln \
                                    --ignore-unfixed=false \
                                    --timeout 10m \
                                    --quiet \
                                    ${IMAGE_NAME}:${IMAGE_TAG} \
                                    > ${SECURITY_REPORT_DIR}/trivy-report.json 2>/dev/null || echo '{}' > ${SECURITY_REPORT_DIR}/trivy-report.json

                                echo "Running Trivy HTML scan for ${IMAGE_NAME}:${IMAGE_TAG}"
                                docker run --rm \
                                    -v /var/run/docker.sock:/var/run/docker.sock \
                                    aquasec/trivy:0.57.1 image \
                                    --format template \
                                    --template "@/contrib/html.tpl" \
                                    --severity LOW,MEDIUM,HIGH,CRITICAL \
                                    --scanners vuln \
                                    --ignore-unfixed=false \
                                    --timeout 10m \
                                    --quiet \
                                    ${IMAGE_NAME}:${IMAGE_TAG} \
                                    > ${SECURITY_REPORT_DIR}/trivy-report.html 2>/dev/null || echo '<html><body><h1>No Trivy report generated</h1></body></html>' > ${SECURITY_REPORT_DIR}/trivy-report.html

                                echo "Trivy scan complete. Report sizes:"
                                wc -c ${SECURITY_REPORT_DIR}/trivy-report.json ${SECURITY_REPORT_DIR}/trivy-report.html
                        '''
                    }
                }
            }
        }

        stage('Scan Repository Secrets') {
            steps {
                container('maven') {
                    script {
                        echo "Scanning repository for secret leaks with Gitleaks..."
                        sh '''
                            mkdir -p ${SECURITY_REPORT_DIR} .tools
                            rm -f ${SECURITY_REPORT_DIR}/gitleaks-report.json \
                                  ${SECURITY_REPORT_DIR}/gitleaks-report.html \
                                  ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt

                            GITLEAKS_ARCHIVE="gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz"
                            GITLEAKS_URL="https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/${GITLEAKS_ARCHIVE}"

                            if [ ! -x .tools/gitleaks ]; then
                                echo "Downloading Gitleaks ${GITLEAKS_VERSION} from ${GITLEAKS_URL}"
                                rm -f ".tools/${GITLEAKS_ARCHIVE}"
                                curl --fail --location --retry 3 --retry-all-errors \
                                    --connect-timeout 15 --max-time 180 --progress-bar \
                                    "${GITLEAKS_URL}" \
                                    --output ".tools/${GITLEAKS_ARCHIVE}"
                                test -s ".tools/${GITLEAKS_ARCHIVE}"
                                ls -lh ".tools/${GITLEAKS_ARCHIVE}"
                                tar -xzf ".tools/${GITLEAKS_ARCHIVE}" -C .tools gitleaks
                                chmod +x .tools/gitleaks
                                ./.tools/gitleaks version
                            fi

                            set +e
                            ./.tools/gitleaks dir . \
                                --config cicd-reference-architectures/phase-1-image-build-jenkins/gitleaks.toml \
                                --gitleaks-ignore-path cicd-reference-architectures/phase-1-image-build-jenkins/.gitleaksignore \
                                --report-format json \
                                --report-path ${SECURITY_REPORT_DIR}/gitleaks-report.json \
                                --redact \
                                --exit-code 1
                            GITLEAKS_STATUS=$?
                            set -e

                            if [ ! -s ${SECURITY_REPORT_DIR}/gitleaks-report.json ]; then
                                echo '[]' > ${SECURITY_REPORT_DIR}/gitleaks-report.json
                            fi

                            FINDINGS_COUNT=$(grep -o '"RuleID"' ${SECURITY_REPORT_DIR}/gitleaks-report.json | wc -l | tr -d ' ')
                            if [ -z "${FINDINGS_COUNT}" ]; then
                                FINDINGS_COUNT=0
                            fi

                            GITLEAKS_STATUS_CLASS=""
                            if [ "${GITLEAKS_STATUS}" -eq 0 ]; then
                                GITLEAKS_STATUS_TEXT="No secrets detected"
                                GITLEAKS_STATUS_CLASS="clean"
                            elif [ "${GITLEAKS_STATUS}" -eq 1 ]; then
                                GITLEAKS_STATUS_TEXT="Secrets detected"
                            else
                                GITLEAKS_STATUS_TEXT="Gitleaks scan error"
                                GITLEAKS_STATUS_CLASS="error"
                            fi

                                                        cat > ${SECURITY_REPORT_DIR}/gitleaks-report.html <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gitleaks Secret Report</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: #f6f8fa; color: #24292f; margin: 0; padding: 32px; }
        .panel { max-width: 900px; margin: 0 auto; background: #fff; border: 1px solid #d0d7de; border-radius: 8px; padding: 24px; }
        .meta { margin-bottom: 16px; color: #57606a; }
        .status { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: 600; margin-bottom: 12px; background: #fff8c5; color: #9a6700; }
        .status.clean { background: #dafbe1; color: #116329; }
        .status.error { background: #ffebe9; color: #cf222e; }
        .actions a { display: inline-block; padding: 8px 14px; border-radius: 6px; background: #1f6feb; color: #fff; text-decoration: none; font-size: 0.9rem; }
        .actions a:hover { background: #1a5fb7; }
        ul { color: #57606a; line-height: 1.6; }
    </style>
</head>
<body>
    <div class="panel">
        <h1>Gitleaks Secret Report</h1>
        <p class="meta">Repository: platform-engineering-reference-architectures</p>
        <p class="status ${GITLEAKS_STATUS_CLASS}">${GITLEAKS_STATUS_TEXT}</p>
        <p class="meta">Findings: ${FINDINGS_COUNT} &middot; Build: ${BUILD_NUMBER}</p>
        <div class="actions">
            <a href="gitleaks-report.json">Open Raw JSON Report</a>
        </div>
        <h2>Summary</h2>
        <ul>
            <li>The JSON report is generated by Gitleaks with redacted findings.</li>
            <li>The pipeline fails when Gitleaks exits with findings or scan errors.</li>
            <li>Use the raw JSON report for exact rule IDs, file paths, and line numbers.</li>
        </ul>
    </div>
</body>
</html>
EOF

                            echo "${GITLEAKS_STATUS}" > ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt
                            echo "Gitleaks scan complete. Status=${GITLEAKS_STATUS}, findings=${FINDINGS_COUNT}"
                            wc -c ${SECURITY_REPORT_DIR}/gitleaks-report.json ${SECURITY_REPORT_DIR}/gitleaks-report.html ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt
                        '''
                    }
                }
            }
        }

        stage('Commit Security Reports') {
            steps {
                container('maven') {
                    script {
                        echo "Committing security reports to repository..."
                        withCredentials([sshUserPrivateKey(credentialsId: "${GITHUB_CREDENTIALS_ID}", keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {
                            dir("${WORKSPACE}") {
                                sh '''
                                    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
                                    if [ -z "${REPO_ROOT}" ]; then
                                        REPO_ROOT="$(find "${WORKSPACE}" -maxdepth 4 -type d -name .git 2>/dev/null | head -n 1 | sed 's|/.git$||')"
                                    fi
                                    if [ -z "${REPO_ROOT}" ]; then
                                        echo "ERROR: Could not locate git repository root under ${WORKSPACE}"
                                        echo "Workspace listing for diagnostics:"
                                        ls -la "${WORKSPACE}" || true
                                        exit 1
                                    fi
                                    echo "Using repository root: ${REPO_ROOT}"
                                    cd "${REPO_ROOT}"

                                    mkdir -p ${SECURITY_REPORT_DIR}
                                    test -f ${SECURITY_REPORT_DIR}/trivy-report.json || echo '{}' > ${SECURITY_REPORT_DIR}/trivy-report.json
                                    test -f ${SECURITY_REPORT_DIR}/trivy-report.html || echo '<html><body><h1>No Trivy report generated</h1></body></html>' > ${SECURITY_REPORT_DIR}/trivy-report.html
                                    test -f ${SECURITY_REPORT_DIR}/gitleaks-report.json || echo '[]' > ${SECURITY_REPORT_DIR}/gitleaks-report.json
                                    test -f ${SECURITY_REPORT_DIR}/gitleaks-report.html || echo '<html><body><h1>No Gitleaks report generated</h1></body></html>' > ${SECURITY_REPORT_DIR}/gitleaks-report.html
                                    test -f ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt || echo '2' > ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt
                                    test -f ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json || echo '{"bomFormat":"CycloneDX","specVersion":"1.6","version":1,"components":[]}' > ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json
                                    test -f ${SECURITY_REPORT_DIR}/sbom.spdx.json || echo '{"spdxVersion":"SPDX-2.3","dataLicense":"CC0-1.0","SPDXID":"SPDXRef-DOCUMENT","name":"No SBOM generated","documentNamespace":"https://example.invalid/no-sbom"}' > ${SECURITY_REPORT_DIR}/sbom.spdx.json
                                    test -f ${SECURITY_REPORT_DIR}/sbom.syft.txt || echo 'No Syft SBOM generated in this build.' > ${SECURITY_REPORT_DIR}/sbom.syft.txt
                                    test -f ${SECURITY_REPORT_DIR}/sbom-report.html || echo '<html><body><h1>No SBOM report generated</h1></body></html>' > ${SECURITY_REPORT_DIR}/sbom-report.html

                                    REPORT_STAGING_DIR="$(mktemp -d)"
                                    cp -R ${SECURITY_REPORT_DIR} "${REPORT_STAGING_DIR}/security-reports"

                                    git rev-parse --is-inside-work-tree
                                    git config user.name "Jenkins CI"
                                    git config user.email "jenkins-ci@local"

                                    # Use SSH key credentials for Git operations.
                                    export GIT_SSH_COMMAND="ssh -i ${SSH_KEY} -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new"

                                    # Jenkins may build an older detached commit while main has moved.
                                    # Rebase the report commit on the latest main before pushing.
                                    git fetch origin main
                                    git reset --hard
                                    git clean -fd
                                    git checkout -B main origin/main
                                    rm -rf ${SECURITY_REPORT_DIR}
                                    cp -R "${REPORT_STAGING_DIR}/security-reports" ${SECURITY_REPORT_DIR}
                                    rm -rf "${REPORT_STAGING_DIR}"

                                    # Publish latest reports to the web dashboard folder.
                                    mkdir -p docs/security-reports
                                    cp ${SECURITY_REPORT_DIR}/trivy-report.html docs/security-reports/trivy-report.html
                                    cp ${SECURITY_REPORT_DIR}/trivy-report.json docs/security-reports/trivy-report.json
                                    cp ${SECURITY_REPORT_DIR}/gitleaks-report.html docs/security-reports/gitleaks-report.html
                                    cp ${SECURITY_REPORT_DIR}/gitleaks-report.json docs/security-reports/gitleaks-report.json
                                    cp ${SECURITY_REPORT_DIR}/sbom-report.html docs/security-reports/sbom-report.html
                                    cp ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json docs/security-reports/sbom.cyclonedx.json
                                    cp ${SECURITY_REPORT_DIR}/sbom.spdx.json docs/security-reports/sbom.spdx.json
                                    cp ${SECURITY_REPORT_DIR}/sbom.syft.txt docs/security-reports/sbom.syft.txt
                                    printf '{"build":"%s","timestamp":"%s"}' "${BUILD_NUMBER}" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > docs/security-reports/build-meta.json

                                    git add ${SECURITY_REPORT_DIR}/trivy-report.json ${SECURITY_REPORT_DIR}/trivy-report.html \
                                            ${SECURITY_REPORT_DIR}/gitleaks-report.json ${SECURITY_REPORT_DIR}/gitleaks-report.html ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt \
                                            ${SECURITY_REPORT_DIR}/sbom-report.html ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json ${SECURITY_REPORT_DIR}/sbom.spdx.json ${SECURITY_REPORT_DIR}/sbom.syft.txt \
                                            docs/security-reports/trivy-report.html docs/security-reports/trivy-report.json \
                                            docs/security-reports/gitleaks-report.html docs/security-reports/gitleaks-report.json \
                                            docs/security-reports/sbom-report.html docs/security-reports/sbom.cyclonedx.json docs/security-reports/sbom.spdx.json docs/security-reports/sbom.syft.txt \
                                            docs/security-reports/build-meta.json

                                    if git diff --staged --quiet; then
                                        echo "No security report changes to commit"
                                    else
                                        git commit -m "chore(security): update security reports for build ${BUILD_NUMBER} [skip ci]"
                                        git push git@github.com:Github-Arun-Repo/platform-engineering-reference-architectures.git HEAD:main
                                    fi
                                '''
                            }
                        }
                    }
                }
            }
        }

        stage('Enforce Security Gates') {
            steps {
                container('maven') {
                    script {
                        echo "Evaluating security gate results..."
                        sh '''
                            GITLEAKS_STATUS="$(cat ${SECURITY_REPORT_DIR}/gitleaks-exit-code.txt 2>/dev/null || echo 2)"
                            if [ "${GITLEAKS_STATUS}" -eq 1 ]; then
                                echo "Gitleaks detected potential secrets. Failing pipeline before registry push."
                                exit 1
                            fi
                            if [ "${GITLEAKS_STATUS}" -gt 1 ]; then
                                echo "Gitleaks scan errored. Failing pipeline before registry push."
                                exit 1
                            fi
                            echo "Security gates passed. No secrets detected."
                        '''
                    }
                }
            }
        }

        stage('Push to Registry') {
            steps {
                container('docker') {
                    script {
                        echo "Pushing Docker image to registry..."
                        withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh '''
                                echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                                docker push ${IMAGE_NAME}:${IMAGE_TAG}
                                docker push ${IMAGE_NAME}:${LATEST_TAG}
                                docker logout
                            '''
                        }
                    }
                }
            }
        }

        stage('Attach SBOM to Image') {
            steps {
                container('docker') {
                    script {
                        echo "Attempting to attach CycloneDX SBOM to image: ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                        withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh '''
                                set +e

                                if [ ! -s ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json ]; then
                                    echo "WARNING: ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json is missing. Skipping image SBOM attachment."
                                    exit 0
                                fi

                                mkdir -p .tools

                                ORAS_ARCHIVE="oras_${ORAS_VERSION}_linux_amd64.tar.gz"
                                ORAS_URL="https://github.com/oras-project/oras/releases/download/v${ORAS_VERSION}/${ORAS_ARCHIVE}"

                                if [ ! -x .tools/oras ]; then
                                    echo "Downloading ORAS ${ORAS_VERSION} from ${ORAS_URL}"
                                    rm -f ".tools/${ORAS_ARCHIVE}"

                                    DOWNLOAD_STATUS=1
                                    if command -v curl >/dev/null 2>&1; then
                                        curl --fail --location --retry 3 --retry-all-errors \
                                            --connect-timeout 15 --max-time 180 --progress-bar \
                                            "${ORAS_URL}" \
                                            --output ".tools/${ORAS_ARCHIVE}"
                                        DOWNLOAD_STATUS=$?
                                    fi

                                    if [ "${DOWNLOAD_STATUS}" -ne 0 ] && command -v wget >/dev/null 2>&1; then
                                        wget -T 30 -O ".tools/${ORAS_ARCHIVE}" "${ORAS_URL}"
                                        DOWNLOAD_STATUS=$?
                                    fi

                                    if [ "${DOWNLOAD_STATUS}" -ne 0 ] && command -v apk >/dev/null 2>&1; then
                                        apk add --no-cache curl tar gzip
                                        APK_STATUS=$?
                                        if [ "${APK_STATUS}" -eq 0 ]; then
                                            curl --fail --location --retry 3 --retry-all-errors \
                                                --connect-timeout 15 --max-time 180 --progress-bar \
                                                "${ORAS_URL}" \
                                                --output ".tools/${ORAS_ARCHIVE}"
                                            DOWNLOAD_STATUS=$?
                                        fi
                                    fi

                                    if [ "${DOWNLOAD_STATUS}" -ne 0 ] || [ ! -s ".tools/${ORAS_ARCHIVE}" ]; then
                                        echo "WARNING: Could not download ORAS. SBOM remains available as Jenkins artifacts and website files; image attachment skipped."
                                        exit 0
                                    fi

                                    tar -xzf ".tools/${ORAS_ARCHIVE}" -C .tools oras
                                    TAR_STATUS=$?
                                    if [ "${TAR_STATUS}" -ne 0 ]; then
                                        echo "WARNING: Could not extract ORAS archive. SBOM image attachment skipped."
                                        exit 0
                                    fi

                                    chmod +x .tools/oras
                                fi

                                ./.tools/oras version
                                ORAS_VERSION_STATUS=$?
                                if [ "${ORAS_VERSION_STATUS}" -ne 0 ]; then
                                    echo "WARNING: ORAS is not executable. SBOM image attachment skipped."
                                    exit 0
                                fi

                                echo "${DOCKER_PASS}" | ./.tools/oras login ${REGISTRY} -u "${DOCKER_USER}" --password-stdin
                                ORAS_LOGIN_STATUS=$?
                                if [ "${ORAS_LOGIN_STATUS}" -ne 0 ]; then
                                    echo "WARNING: ORAS login failed. SBOM image attachment skipped."
                                    exit 0
                                fi

                                ./.tools/oras attach ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
                                    --artifact-type application/vnd.cyclonedx+json \
                                    --annotation org.opencontainers.image.title="CycloneDX SBOM for ${IMAGE_NAME}:${IMAGE_TAG}" \
                                    ${SECURITY_REPORT_DIR}/sbom.cyclonedx.json:application/vnd.cyclonedx+json
                                ORAS_ATTACH_STATUS=$?

                                ./.tools/oras logout ${REGISTRY} || true

                                if [ "${ORAS_ATTACH_STATUS}" -ne 0 ]; then
                                    echo "WARNING: ORAS attach failed. SBOM remains available as Jenkins artifacts and website files."
                                    exit 0
                                fi

                                echo "CycloneDX SBOM attached to ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}."
                            '''
                        }
                    }
                }
            }
        }

        stage('Update Deployment Manifests') {
            steps {
                script {
                    echo "Updating Kubernetes deployment manifests with new image tag..."
                    // This would typically update your ArgoCD git repo or deployment files
                    // For now, just logging the image reference
                    sh "echo 'Image built and pushed: ${IMAGE_NAME}:${IMAGE_TAG}'"
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Pipeline execution completed"
                // Archive build artifacts if needed
                archiveArtifacts artifacts: 'cicd-reference-architectures/sample-application/target/**/*.jar,security-reports/trivy-report.json,security-reports/trivy-report.html,security-reports/gitleaks-report.json,security-reports/gitleaks-report.html,security-reports/gitleaks-exit-code.txt,security-reports/sbom-report.html,security-reports/sbom.cyclonedx.json,security-reports/sbom.spdx.json,security-reports/sbom.syft.txt', allowEmptyArchive: true

                publishHTML(target: [
                    reportDir: 'security-reports',
                    reportFiles: 'trivy-report.html',
                    reportName: 'Trivy CVE Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: true
                ])

                publishHTML(target: [
                    reportDir: 'security-reports',
                    reportFiles: 'gitleaks-report.html',
                    reportName: 'Gitleaks Secret Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: true
                ])

                publishHTML(target: [
                    reportDir: 'security-reports',
                    reportFiles: 'sbom-report.html',
                    reportName: 'Image SBOM Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: true
                ])

                sh '''
                    echo "Current user:"
                    id || true

                    echo "Fixing workspace permissions..."
                    chmod -R u+rwX "${WORKSPACE}" 2>/dev/null || true
                '''

                try {
                    deleteDir()
                } catch (Exception e) {
                    echo "Could not clean workspace: ${e.message}"
                }
            }
        }
        success {
            script {
                echo "Build successful! Image: ${IMAGE_NAME}:${IMAGE_TAG}"
                // Notify teams (Slack, email, etc.)
            }
        }
        failure {
            script {
                echo "Build failed!"
                // Notify teams about failure
            }
        }
    }
}
