pipeline {
    agent {
        kubernetes {
            label 'todo-app'
            defaultContainer 'maven'
            yamlFile 'cicd-reference-architectures/phase-1-image-build-jenkins/pod-template.yaml'
        }
    }

    environment {
        PIPELINE_VERSION = 'cleanup-fix-v3-2026-07-16'
        REGISTRY = 'docker.io'  // Change to your registry: gcr.io, ecr, etc.
        IMAGE_NAME = 'agovindasamy/arun'
        IMAGE_TAG = "${BUILD_NUMBER}"
        LATEST_TAG = 'latest'
        GIT_REPO = 'https://github.com/Github-Arun-Repo/platform-engineering-reference-architectures.git'
        GITHUB_CREDENTIALS_ID = 'github-arun-repository'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-credentials'
        SECURITY_REPORT_DIR = 'security-reports'
        SONARQUBE_SERVER = 'SonarQube'  // Configure in Jenkins
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '15'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Pipeline version: ${PIPELINE_VERSION}"
                    echo "Checking out source code from ${GIT_REPO}"
                }
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[url: "${GIT_REPO}", credentialsId: "${GITHUB_CREDENTIALS_ID}"]]
                ])
            }
        }

        stage('Build & Test') {
            steps {
                container('maven') {
                    script {
                        echo "Building and testing TODO application..."
                        dir('cicd-reference-architectures/sample-application') {
                            sh 'mvn clean test'
                        }
                    }
                }
            }
        }

        // stage('Code Quality Analysis') {
        //     // Requires: SonarQube server + sonar Jenkins plugin (plugin ID: sonar)
        //     // Skip this stage if SonarQube is not configured in your environment
        //     steps {
        //         script {
        //             echo "Running SonarQube analysis..."
        //             dir('cicd-reference-architectures/sample-application') {
        //                 withSonarQubeEnv("${SONARQUBE_SERVER}") {
        //                     sh 'mvn sonar:sonar'
        //                 }
        //             }
        //         }
        //     }
        // }

        stage('Build Application') {
            steps {
                container('maven') {
                    script {
                        echo "Packaging Spring Boot application..."
                        dir('cicd-reference-architectures/sample-application') {
                            sh 'mvn clean package -DskipTests'
                        }
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                container('docker') {
                    script {
                        echo "Building Docker image: ${IMAGE_NAME}:${IMAGE_TAG}"
                        dir('cicd-reference-architectures/sample-application') {
                            sh '''
                                docker build \
                                    -t ${IMAGE_NAME}:${IMAGE_TAG} \
                                    -t ${IMAGE_NAME}:${LATEST_TAG} \
                                    -f Dockerfile .
                            '''
                        }
                    }
                }
            }
        }

        stage('Scan Docker Image') {
            steps {
                container('docker') {
                    script {
                        echo "Scanning Docker image for vulnerabilities..."
                        // Security gating policy is intentionally not enforced in this pipeline.
                        // This stage always generates reports and never fails the build.
                        sh '''
                            mkdir -p ${SECURITY_REPORT_DIR}
                            rm -f ${SECURITY_REPORT_DIR}/trivy-report.json ${SECURITY_REPORT_DIR}/trivy-report.html

                            docker run --rm \
                                -v /var/run/docker.sock:/var/run/docker.sock \
                                -v "${PWD}:/work" \
                                aquasec/trivy:0.57.1 image \
                                --config /work/cicd-reference-architectures/phase-1-image-build-jenkins/trivy.yaml \
                                --format json \
                                --output /work/${SECURITY_REPORT_DIR}/trivy-report.json \
                                ${IMAGE_NAME}:${IMAGE_TAG} || true

                            docker run --rm \
                                -v /var/run/docker.sock:/var/run/docker.sock \
                                -v "${PWD}:/work" \
                                aquasec/trivy:0.57.1 image \
                                --config /work/cicd-reference-architectures/phase-1-image-build-jenkins/trivy.yaml \
                                --format template \
                                --template "@/contrib/html.tpl" \
                                --output /work/${SECURITY_REPORT_DIR}/trivy-report.html \
                                ${IMAGE_NAME}:${IMAGE_TAG} || true
                        '''
                    }
                }
            }
        }

        stage('Commit Security Reports') {
            steps {
                container('maven') {
                    script {
                        echo "Committing Trivy reports to repository..."
                        withCredentials([usernamePassword(credentialsId: "${GITHUB_CREDENTIALS_ID}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                            sh '''
                                test -f ${SECURITY_REPORT_DIR}/trivy-report.json || echo '{}' > ${SECURITY_REPORT_DIR}/trivy-report.json
                                test -f ${SECURITY_REPORT_DIR}/trivy-report.html || echo '<html><body><h1>No Trivy report generated</h1></body></html>' > ${SECURITY_REPORT_DIR}/trivy-report.html

                                git config user.name "Jenkins CI"
                                git config user.email "jenkins-ci@local"

                                git add ${SECURITY_REPORT_DIR}/trivy-report.json ${SECURITY_REPORT_DIR}/trivy-report.html

                                if git diff --staged --quiet; then
                                    echo "No security report changes to commit"
                                else
                                    git commit -m "chore(security): update trivy reports for build ${BUILD_NUMBER} [skip ci]"
                                    git push https://${GIT_USER}:${GIT_TOKEN}@github.com/Github-Arun-Repo/platform-engineering-reference-architectures.git HEAD:main
                                fi
                            '''
                        }
                    }
                }
            }
        }

        stage('Push to Registry') {
            steps {
                container('docker') {
                    script {
                        echo "Pushing Docker image to registry..."
                        withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh '''
                                echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                                docker push ${IMAGE_NAME}:${IMAGE_TAG}
                                docker push ${IMAGE_NAME}:${LATEST_TAG}
                                docker logout
                            '''
                        }
                    }
                }
            }
        }

        stage('Update Deployment Manifests') {
            steps {
                script {
                    echo "Updating Kubernetes deployment manifests with new image tag..."
                    // This would typically update your ArgoCD git repo or deployment files
                    // For now, just logging the image reference
                    sh "echo 'Image built and pushed: ${IMAGE_NAME}:${IMAGE_TAG}'"
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Pipeline execution completed"
                // Archive build artifacts if needed
                archiveArtifacts artifacts: 'cicd-reference-architectures/sample-application/target/**/*.jar,security-reports/trivy-report.json,security-reports/trivy-report.html', allowEmptyArchive: true

                publishHTML(target: [
                    reportDir: 'security-reports',
                    reportFiles: 'trivy-report.html',
                    reportName: 'Trivy CVE Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: true
                ])

                sh '''
                    echo "Current user:"
                    id || true

                    echo "Fixing workspace permissions..."
                    chmod -R u+rwX "${WORKSPACE}" 2>/dev/null || true
                '''

                try {
                    deleteDir()
                } catch (Exception e) {
                    echo "Could not clean workspace: ${e.message}"
                }
            }
        }
        success {
            script {
                echo "Build successful! Image: ${IMAGE_NAME}:${IMAGE_TAG}"
                // Notify teams (Slack, email, etc.)
            }
        }
        failure {
            script {
                echo "Build failed!"
                // Notify teams about failure
            }
        }
    }
}
